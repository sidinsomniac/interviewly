# ===========================================
# Microsoft / Teams (RecipeBari tenant)
# Required for MVP. See docs/10-ENV-VARS.md and docs/03-MICROSOFT-INTEGRATION.md.
#
# MS_BOT_USER_EMAIL — the UPN whose delegated token Medha uses to read
#   /me/chats and post into meeting chats. The bot must be invited to
#   any meeting it should join.
#
# MS_ORGANIZER_EMAIL — drives TWO behaviours:
#   1. Meeting-lookup filter for findMeetingChatByTopic: the bot will
#      only consider meeting chats whose `onlineMeetingInfo.organizer.id`
#      matches the AAD GUID of this email. Change this env to switch
#      which organizer's meetings the bot listens for (e.g. swap
#      SiddharthaChatterjee@... ↔ RatanPatra@... at booth time).
#   2. Fallback transcript fetcher at end-time: when the interview
#      record has no organizerGuid, the end-route resolves this email
#      to an organizer to fetch the meeting transcript from.
#   If you change this and re-submit the same meetingTopic, the lookup
#   may fail with "Topic matched but no chats organized by ..." — that
#   means the bot was never invited by the new organizer (expected).
# ===========================================
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_BOT_USER_EMAIL=demo.bot@abc.onmicrosoft.com
MS_BOT_USER_PASSWORD=
MS_ORGANIZER_EMAIL=admin@abc.onmicrosoft.com

# ===========================================
# LLM
# Required for MVP. See docs/07-LLM-PROMPTS.md.
#
# Default (Phase 1.5): DeepSeek V4 Flash, thinking disabled.
# Override MODEL_PROVIDER to flip providers without touching code.
#
# Model IDs available on the API as of 2026-05-27:
#   - deepseek-v4-flash  (faster, used here; hybrid — we disable thinking)
#   - deepseek-v4-pro    (larger; not used)
# Thinking is suppressed at runtime via `thinking:{type:"disabled"}`
# in src/lib/llm.ts (deepseek branch).
# ===========================================
MODEL_PROVIDER=deepseek
MODEL_ID=deepseek-v4-flash
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1  # override if needed

# Alternate providers — populate the matching key and flip MODEL_PROVIDER.
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# Example: MODEL_PROVIDER=google, MODEL_ID=gemini-2.5-flash-lite

# ===========================================
# Test mode (dev only)
# When MEDHA_TEST_MODE=true, End Interview skips the real Graph
# transcript fetch + chat history fetch and uses fixture files under
# data/fixtures/. Question/welcome post buttons are also stubbed (they
# update local state but don't call Graph). Lets you exercise the full
# pipeline in <30 sec without sitting through a real Teams meeting.
#
# NEXT_PUBLIC_MEDHA_TEST_MODE mirrors the flag to the client so the
# live dashboard can show a "Test mode" banner.
#
# MEDHA_TEST_FIXTURE_ROLE — DEV OVERRIDE. When set, forces the
# end-route to load `transcript-<thisValue>-<outcome>.vtt` regardless
# of the interview's actual roleId. Useful for testing a role's UI
# end-to-end when its own fixture doesn't exist yet (e.g. pick
# "Frontend Engineer" in the form but reuse the existing "core"
# fixture by setting MEDHA_TEST_FIXTURE_ROLE=core). Leave UNSET to
# make the end-route use the interview's actual roleId at lookup.
#
# MEDHA_TEST_FIXTURE_OUTCOME — typically "good-hire" or "no-hire".
# Picks the variant within the chosen role's fixture set.
# ===========================================
MEDHA_TEST_MODE=false
NEXT_PUBLIC_MEDHA_TEST_MODE=false
# MEDHA_TEST_FIXTURE_ROLE=react     # leave commented to use interview's roleId
MEDHA_TEST_FIXTURE_OUTCOME=good-hire

# ===========================================
# Bot sidecar (Scope Y)
# Medha → medha-bot sidecar integration for live transcript + branching.
#
# When BOTH are set, the /auto-conduct/start route POSTs to the bot's
# /api/bot/join endpoint to make it join the Teams meeting; the sidecar
# then streams transcript chunks back to /api/interviews/{id}/live-transcript.
# DeepSeek decides per-utterance whether to ask a branching follow-up.
#
# When either is unset, Medha falls back to Scope X chat-keyword + timer
# only (no live transcript, no branching). The bot's absence is non-fatal —
# the conductor logs a warning and continues.
#
# MEDHA_BOT_SHARED_SECRET must match the sidecar's secret on the bot VM
# (see medha-bot/CLAUDE_NOTES.md). Any random string works; rotate together.
# ===========================================
# MEDHA_BOT_BASE_URL=https://bot.medha-by.space
# MEDHA_BOT_SHARED_SECRET=<random-secret-changeme>

# ===========================================
# App config
# Note: dotenv breaks on spaces around `=`. Keep `KEY=value` exact.
# ===========================================
NEXTAUTH_URL=http://localhost:3000
LOG_LEVEL=info
INTERVIEWLY_OUTPUT_DIR=./data/output
MEDHA_BASE_URL=https://bot.medha-by.space
# MEDHA_BASE_URL=https://defection-shorter-salami.ngrok-free.dev
