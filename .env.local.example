# ===========================================
# Microsoft / Teams (RecipeBari tenant)
# Required for MVP. See docs/10-ENV-VARS.md and docs/03-MICROSOFT-INTEGRATION.md.
# ===========================================
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_BOT_USER_EMAIL=demo.bot@abc.onmicrosoft.com
MS_BOT_USER_PASSWORD=
MS_ORGANIZER_EMAIL=admin@abc.onmicrosoft.com

# ===========================================
# LLM
# Required for MVP. See docs/07-LLM-PROMPTS.md.
# ===========================================
MODEL_PROVIDER=google
MODEL_ID=gemini-2.5-flash-lite
GEMINI_API_KEY=

# (Optional fallbacks if you swap provider)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ===========================================
# App config
# ===========================================
NEXTAUTH_URL=http://localhost:3000
LOG_LEVEL=info
INTERVIEWLY_OUTPUT_DIR=./data/output
MEDHA_BASE_URL = https://defection-shorter-salami.ngrok-free.dev
