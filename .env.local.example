# ===========================================
# Microsoft / Teams (RecipeBari tenant)
# Required for MVP. See docs/10-ENV-VARS.md and docs/03-MICROSOFT-INTEGRATION.md.
# ===========================================
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_BOT_USER_EMAIL=demo.bot@abc.onmicrosoft.com
MS_BOT_USER_PASSWORD=
MS_ORGANIZER_EMAIL=admin@abc.onmicrosoft.com

# ===========================================
# LLM
# Required for MVP. See docs/07-LLM-PROMPTS.md.
#
# Default (Phase 1.5): DeepSeek V4 Flash, thinking disabled.
# Override MODEL_PROVIDER to flip providers without touching code.
#
# Model IDs available on the API as of 2026-05-27:
#   - deepseek-v4-flash  (faster, used here; hybrid — we disable thinking)
#   - deepseek-v4-pro    (larger; not used)
# Thinking is suppressed at runtime via `thinking:{type:"disabled"}`
# in src/lib/llm.ts (deepseek branch).
# ===========================================
MODEL_PROVIDER=deepseek
MODEL_ID=deepseek-v4-flash
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1  # override if needed

# Alternate providers — populate the matching key and flip MODEL_PROVIDER.
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# Example: MODEL_PROVIDER=google, MODEL_ID=gemini-2.5-flash-lite

# ===========================================
# Test mode (dev only)
# When MEDHA_TEST_MODE=true, End Interview skips the real Graph
# transcript fetch + chat history fetch and uses fixture files under
# data/fixtures/. Lets you exercise the full pipeline in <30 sec
# without sitting through a real 30–60 min Teams meeting.
#
# NEXT_PUBLIC_MEDHA_TEST_MODE mirrors the flag to the client so the
# live dashboard can show a "Test mode" banner.
# FIXTURE_ROLE controls which transcript file is read
# (data/fixtures/transcript-<role>-<outcome>.vtt).
# ===========================================
MEDHA_TEST_MODE=false
NEXT_PUBLIC_MEDHA_TEST_MODE=false
MEDHA_TEST_FIXTURE_ROLE=react
MEDHA_TEST_FIXTURE_OUTCOME=good-hire

# ===========================================
# App config
# Note: dotenv breaks on spaces around `=`. Keep `KEY=value` exact.
# ===========================================
NEXTAUTH_URL=http://localhost:3000
LOG_LEVEL=info
INTERVIEWLY_OUTPUT_DIR=./data/output
MEDHA_BASE_URL=https://defection-shorter-salami.ngrok-free.dev
